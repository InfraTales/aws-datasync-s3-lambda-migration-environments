{
  "name": "infratales-manual-pilot",
  "private": true,
  "scripts": {
    "build": "tsc --noEmit",
    "synth": "cdk synth",
    "test": "npm run test:unit",
    "test:unit": "jest --runInBand --passWithNoTests --testPathIgnorePatterns=\\\\.int\\\\.test\\\\.ts$",
    "test:integration": "jest --runInBand --passWithNoTests --testPathPatterns=\\\\.int\\\\.test\\\\.ts$"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.180.0",
    "constructs": "^10.4.2",
    "ts-node": "^10.9.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/jest": "^29.5.14",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.2",
    "@aws-sdk/client-cloudformation": "^3.0.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.0.0",
    "@aws-sdk/client-database-migration-service": "^3.0.0",
    "@aws-sdk/client-ec2": "^3.0.0",
    "@aws-sdk/client-glue": "^3.0.0",
    "@aws-sdk/client-lambda": "^3.0.0",
    "@aws-sdk/client-rds": "^3.0.0",
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/client-sfn": "^3.0.0",
    "@aws-sdk/client-sns": "^3.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node"
  }
}
